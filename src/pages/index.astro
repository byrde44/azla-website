---
import Base from '../layouts/Base.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import { SITE, SERVICES } from '../consts';

const faq = [
  {
    q: 'Wat kost een website bij AZLA Solutions?',
    a: 'Een professionele maatwerkwebsite start vanaf €1.950. De exacte investering hangt af van omvang en doelen — na een gratis strategiegesprek krijg je een vaste prijs, zonder verrassingen achteraf.',
  },
  {
    q: 'Hoe snel word ik gevonden in Google?',
    a: 'Voor lokale zoektermen zoals "webdesign Rotterdam" zien klanten vaak binnen 4 tot 8 weken beweging. Landelijke, competitieve termen kosten 3 tot 12 maanden. We werken met een concreet plan per maand, zodat je precies weet waar je aan toe bent.',
  },
  {
    q: 'Wat betekent vindbaar zijn in ChatGPT en AI-zoekmachines?',
    a: 'Steeds meer mensen vragen aan ChatGPT, Perplexity of Gemini om een bedrijf aan te bevelen. Wij optimaliseren je website technisch en inhoudelijk (GEO: Generative Engine Optimization) zodat AI-assistenten jouw bedrijf citeren en aanbevelen. Onderzoek toont 30-115% meer AI-zichtbaarheid na optimalisatie.',
  },
  {
    q: 'Werken jullie alleen in de regio Rotterdam?',
    a: 'Ons hart ligt in de regio Rotterdam — Krimpen aan den IJssel, Capelle en omstreken — maar we werken volledig online en helpen ondernemers door heel Nederland.',
  },
  {
    q: 'Wat maakt AZLA anders dan een standaard webdesignbureau?',
    a: 'De meeste bureaus leveren een WordPress-site op en zwaaien je uit. Wij bouwen razendsnelle maatwerksites (laadtijd onder 1 seconde) en combineren dat met SEO, AI-vindbaarheid en advertenties. Eén partner, één doel: meetbaar meer klanten.',
  },
];

const stats = [
  { n: '<1s', label: 'laadtijd — sneller dan 95% van alle websites' },
  { n: '100', label: 'Google PageSpeed-score als standaard, geen uitzondering' },
  { n: '24u', label: 'reactietijd — je wacht nooit dagen op antwoord' },
];

const icons: Record<string, string> = {
  design: 'M4 5h16v11H4z M2 19h20 M9 16v3 M15 16v3',
  search: 'M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14z M21 21l-4.5-4.5',
  ads: 'M3 11l18-7-7 18-2.5-8.5L3 11z',
};
---

<Base
  title="AZLA Solutions | Webdesign, SEO & Online Marketing — regio Rotterdam"
  description="Premium webdesignbureau in de regio Rotterdam. Razendsnelle websites, top-rankings in Google en vindbaar in ChatGPT & AI-zoekmachines. Plan een gratis strategiegesprek."
>
  <!-- HERO -->
  <section class="hero">
    <div class="glow" style="top:-120px; right:-80px; width:480px; height:480px; background:var(--accent);"></div>
    <div class="container">
      <span class="kicker">Webdesign · SEO · Social Ads — regio Rotterdam</span>
      <h1>
        Websites die <span class="accent">klanten opleveren</span>.<br />
        Niet alleen mooi staan.
      </h1>
      <p class="lead">
        {SITE.name} bouwt razendsnelle maatwerkwebsites en zorgt dat je gevonden wordt —
        in Google én in AI-zoekmachines zoals ChatGPT. Premium werk, meetbaar resultaat.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Plan gratis strategiegesprek <span class="arrow">→</span></a>
        <a href="/gratis-website-scan" class="btn btn-ghost">Gratis website-scan</a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section-alt">
    <div class="container stats-grid">
      {stats.map((s) => (
        <div class="stat reveal">
          <span class="stat-n">{s.n}</span>
          <span class="muted">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- DIENSTEN -->
  <section class="section">
    <div class="container">
      <span class="kicker">Wat we doen</span>
      <h2>Drie diensten. Eén doel:<br />meetbaar meer omzet.</h2>
      <div class="grid-3 mt-2">
        {SERVICES.map((s) => (
          <a href={`/diensten/${s.slug}`} class="card service-card reveal">
            <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="accent" aria-hidden="true">
              <path d={icons[s.icon]} />
            </svg>
            <h3>{s.title}</h3>
            <p class="muted">{s.short}</p>
            <span class="card-link">Meer over {s.title.split(' ')[0].toLowerCase()} <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WAAROM -->
  <section class="section section-alt">
    <div class="container why-grid">
      <div class="reveal">
        <span class="kicker">Waarom AZLA</span>
        <h2>De meeste websites zijn digitale visitekaartjes. Wij bouwen verkoopmachines.</h2>
      </div>
      <div class="why-items">
        <div class="why-item reveal">
          <h3>01 — Techniek die wint</h3>
          <p class="muted">Geen trage WordPress-templates. Wij bouwen maatwerk dat in milliseconden laadt. Google beloont dat direct met betere rankings — en bezoekers met meer vertrouwen.</p>
        </div>
        <div class="why-item reveal">
          <h3>02 — Gevonden in Google én AI</h3>
          <p class="muted">Wij zijn een van de weinige bureaus in Nederland die websites standaard optimaliseren voor AI-zoekmachines (ChatGPT, Perplexity, Gemini). Daar zit de groei van de komende jaren.</p>
        </div>
        <div class="why-item reveal">
          <h3>03 — Alles meetbaar</h3>
          <p class="muted">Je krijgt geen vaag rapport, maar een helder dashboard: zoveel bezoekers, zoveel aanvragen, zoveel omzet. Elke euro verantwoord.</p>
        </div>
        <div class="why-item reveal">
          <h3>04 — Eén aanspreekpunt</h3>
          <p class="muted">Website, SEO en advertenties uit één hand, perfect op elkaar afgestemd. Korte lijnen, snelle actie, geen doorverwijs-circus.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faq} />
  <CTA />
</Base>

<style>
  .hero { position: relative; overflow: hidden; padding: clamp(5rem, 12vw, 9rem) 0 clamp(4rem, 8vw, 6rem); }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2.4rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; padding: 3rem 0; }
  .stat { display: flex; flex-direction: column; gap: .3rem; }
  .stat-n { font-family: var(--font-display); font-size: clamp(2.2rem, 4vw, 3.2rem); font-weight: 700; color: var(--accent); }
  @media (max-width: 800px) { .stats-grid { grid-template-columns: 1fr; padding: 2rem 0; } }

  .service-card { text-decoration: none; display: flex; flex-direction: column; gap: 1rem; }
  .service-card h3 { margin: 0; }
  .service-card p { flex: 1; margin: 0; }
  .card-link { font-family: var(--font-display); font-weight: 600; font-size: .92rem; color: var(--accent); }

  .why-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: start; }
  .why-grid > div:first-child { position: sticky; top: 110px; }
  .why-item { border-top: 1px solid var(--border); padding-top: 1.6rem; margin-bottom: 2.4rem; }
  .why-item h3 { font-size: 1.15rem; }
  @media (max-width: 900px) { .why-grid { grid-template-columns: 1fr; gap: 2rem; } .why-grid > div:first-child { position: static; } }
</style>
