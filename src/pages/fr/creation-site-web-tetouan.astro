---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const PRICE = '15 000 MAD';
const waMsg = encodeURIComponent('Bonjour ! Je souhaite un devis pour un site web à Tétouan.');
const wa = `https://wa.me/${SITE.whatsapp}?text=${waMsg}`;

const FR_URL = `${SITE.domain}/fr/creation-site-web-tetouan`;
const AR_URL = `${SITE.domain}/ar/tasmim-mawaqi-tetouan`;
const alternates = [
  { hreflang: 'fr', href: FR_URL },
  { hreflang: 'ar', href: AR_URL },
  { hreflang: 'x-default', href: FR_URL },
];

const faq = [
  { q: 'Combien coûte la création d’un site web à Tétouan ?', a: `Nos sites premium sur mesure démarrent à ${PRICE}, textes optimisés SEO, hébergement première année et visibilité IA (ChatGPT) inclus. Prix fixe convenu à l’avance — aucun supplément surprise.` },
  { q: 'Travaillez-vous à distance ou sur place à Tétouan ?', a: 'Les deux. AZLA est un studio néerlandais aux racines tétouanaises : nous travaillons en ligne (WhatsApp, visio) et sommes régulièrement à Tétouan pour rencontrer nos clients en personne.' },
  { q: 'Qu’est-ce que la visibilité dans ChatGPT (GEO) ?', a: 'De plus en plus de clients demandent à ChatGPT ou Gemini de recommander une entreprise. Nous optimisons votre site (données structurées, contenu citable) pour que l’IA recommande votre établissement — quasiment aucune agence au Maroc ne le propose aujourd’hui.' },
  { q: 'En combien de temps mon site est-il en ligne ?', a: 'En général 3 à 4 semaines entre le premier échange et la mise en ligne : design semaine 1, développement et textes semaines 2-3, lancement semaine 4.' },
  { q: 'Le site sera-t-il rapide et adapté au mobile ?', a: 'Oui — c’est notre signature. Temps de chargement inférieur à 1 seconde et design pensé d’abord pour mobile, là où navigue la majorité de vos clients marocains.' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Création de site web à Tétouan',
    description: 'Création de sites web premium à Tétouan : design européen, chargement < 1 seconde, référencement Google et visibilité dans les IA comme ChatGPT.',
    provider: { '@id': `${SITE.domain}/#organization` },
    areaServed: [{ '@type': 'City', name: 'Tétouan' }, { '@type': 'Country', name: 'Maroc' }],
    serviceType: 'Création de site web',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((i) => ({ '@type': 'Question', name: i.q, acceptedAnswer: { '@type': 'Answer', text: i.a } })),
  },
];
---

<Base
  title="Création site web Tétouan | Agence web premium — AZLA"
  description="Agence web à Tétouan : sites premium aux standards européens, chargement < 1s, visibles sur Google et ChatGPT. Racines tétouanaises, qualité néerlandaise."
  lang="fr"
  chrome={false}
  alternates={alternates}
  schema={schema}
>
  <header class="fr-header">
    <div class="container fr-header-inner">
      <a href="/fr/creation-site-web-tetouan" class="logo">AZLA<span class="accent">.</span></a>
      <nav class="fr-nav">
        <a href="/ar/tasmim-mawaqi-tetouan" class="lang-link">العربية</a>
        <a href="/" class="lang-link">NL</a>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary fr-cta">Devis gratuit</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="glow" style="top:-120px; right:-80px; width:460px; height:460px; background:var(--accent);"></div>
    <div class="container">
      <span class="kicker">Agence web · Tétouan & Nord du Maroc</span>
      <h1>Un site web aux <span class="accent">standards européens</span>,<br />des racines tétouanaises</h1>
      <p class="lead">
        AZLA crée des sites premium pour les entreprises de Tétouan : chargement en moins d'une seconde,
        visibles sur Google <em>et</em> recommandés par les IA comme ChatGPT. Conçus aux Pays-Bas, pensés pour le Maroc.
      </p>
      <div class="hero-actions">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary">Devis gratuit sur WhatsApp <span class="arrow">→</span></a>
        <a href="#tarifs" class="btn btn-ghost">Voir les tarifs</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <span class="kicker">Pourquoi AZLA</span>
      <h2>Ce que les agences locales ne proposent pas (encore)</h2>
      <div class="grid-3 mt-2">
        <div class="card reveal">
          <h3>Vitesse &lt; 1 seconde</h3>
          <p class="muted" style="margin:0">La plupart des sites au Maroc chargent en 4 à 8 secondes — et perdent la moitié de leurs visiteurs. Nos sites chargent en moins d'une seconde, même en 3G. Google le récompense directement.</p>
        </div>
        <div class="card reveal">
          <h3>Visible dans ChatGPT</h3>
          <p class="muted" style="margin:0">Vos futurs clients demandent déjà à l'IA de leur recommander un hôtel, un riad, un cabinet. Nous optimisons votre site pour ces réponses (GEO) — une longueur d'avance que presque personne n'a au Maroc.</p>
        </div>
        <div class="card reveal">
          <h3>Design premium européen</h3>
          <p class="muted" style="margin:0">Un design sur mesure qui inspire confiance aux clients marocains comme aux visiteurs européens — idéal pour le tourisme, l'immobilier et les services haut de gamme.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="kicker">Pour qui</span>
      <h2>Conçu pour les entreprises de Tétouan</h2>
      <div class="grid-3 mt-2">
        <div class="card reveal"><h3>Riads & hôtels</h3><p class="muted" style="margin:0">Réservations directes au lieu de commissions Booking. Site multilingue FR/EN/AR qui convertit les visiteurs européens.</p></div>
        <div class="card reveal"><h3>Restaurants & cafés</h3><p class="muted" style="margin:0">Menu en ligne, réservation WhatsApp, photos qui donnent faim — et une fiche Google impeccable.</p></div>
        <div class="card reveal"><h3>Services & professions libérales</h3><p class="muted" style="margin:0">Avocats, cliniques, immobilier, artisans : un site qui positionne votre cabinet comme la référence de la région.</p></div>
      </div>
    </div>
  </section>

  <section class="section section-alt" id="tarifs">
    <div class="container">
      <span class="kicker">Tarifs</span>
      <h2>Un investissement, pas une dépense</h2>
      <div class="grid-2 mt-2" style="max-width:860px">
        <div class="card reveal">
          <h3>Site Premium</h3>
          <p class="muted">Site sur mesure 5-8 pages, textes optimisés, SEO + visibilité IA, hébergement 1<sup>re</sup> année inclus.</p>
          <p style="font-family:var(--font-display); font-size:1.9rem; font-weight:700; margin:0" class="accent">à partir de {PRICE}</p>
        </div>
        <div class="card reveal">
          <h3>Sur devis</h3>
          <p class="muted">E-commerce, réservation en ligne, multilingue complet ou projet spécifique ? Chaque projet reçoit un prix fixe, convenu à l'avance.</p>
          <a href={wa} target="_blank" rel="noopener" class="btn btn-ghost">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">
      <span class="kicker">FAQ</span>
      <h2>Questions fréquentes</h2>
      <div class="mt-2">
        {faq.map((item) => (
          <details class="faq-item reveal">
            <summary>{item.q}</summary>
            <p class="muted">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container center">
      <h2>Parlons de votre projet</h2>
      <p class="lead" style="margin:0 auto 2rem">Réponse en moins de 24 h, en français, en arabe ou en darija. Premier échange gratuit et sans engagement.</p>
      <a href={wa} target="_blank" rel="noopener" class="btn btn-primary">Écrivez-nous sur WhatsApp <span class="arrow">→</span></a>
    </div>
  </section>

  <footer class="fr-footer">
    <div class="container fr-footer-inner">
      <span class="logo">AZLA<span class="accent">.</span></span>
      <span class="muted">Tétouan · Rotterdam — {SITE.email} · <a href={wa} style="color:var(--accent)">WhatsApp</a> · <a href="https://www.instagram.com/azlasolutions/" style="color:var(--text)">Instagram</a></span>
      <span class="muted">© 2026 AZLA Solutions · <a href="/ar/tasmim-mawaqi-tetouan" style="color:var(--text)">العربية</a> · <a href="/" style="color:var(--text)">Nederlands</a></span>
    </div>
  </footer>
</Base>

<style>
  .fr-header { position: sticky; top: 0; z-index: 50; background: rgba(10,10,15,.85); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); }
  .fr-header-inner { display: flex; align-items: center; justify-content: space-between; height: 70px; }
  .logo { font-family: var(--font-display); font-weight: 700; font-size: 1.4rem; text-decoration: none; }
  .fr-nav { display: flex; align-items: center; gap: 1.2rem; }
  .lang-link { color: var(--muted); text-decoration: none; font-size: .95rem; }
  .lang-link:hover { color: var(--accent); }
  .fr-cta { padding: .55rem 1.2rem; font-size: .9rem; }
  .hero { position: relative; overflow: hidden; padding: clamp(4.5rem, 10vw, 8rem) 0 clamp(3.5rem, 7vw, 5rem); }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2.2rem; }
  .faq-item { border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); margin-bottom: .8rem; padding: 0 1.4rem; }
  summary { cursor: pointer; font-family: var(--font-display); font-weight: 600; padding: 1.2rem 0; list-style: none; position: relative; padding-inline-end: 2rem; }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: '+'; position: absolute; inset-inline-end: 0; top: 50%; transform: translateY(-50%); color: var(--accent); font-size: 1.4rem; }
  details[open] summary::after { content: '–'; }
  .faq-item p { padding-bottom: 1.2rem; margin: 0; }
  .fr-footer { border-top: 1px solid var(--border); background: var(--bg-elev); padding: 2rem 0; margin-top: 3rem; }
  .fr-footer-inner { display: flex; flex-direction: column; gap: .5rem; align-items: center; text-align: center; font-size: .9rem; }
  .fr-footer a { text-decoration: none; }
</style>
