---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const PRICE = '15.000 درهم';
const waMsg = encodeURIComponent('السلام عليكم! أريد عرض سعر لموقع إلكتروني في تطوان.');
const wa = `https://wa.me/${SITE.whatsapp}?text=${waMsg}`;

const FR_URL = `${SITE.domain}/fr/creation-site-web-tetouan`;
const AR_URL = `${SITE.domain}/ar/tasmim-mawaqi-tetouan`;
const alternates = [
  { hreflang: 'fr', href: FR_URL },
  { hreflang: 'ar', href: AR_URL },
  { hreflang: 'x-default', href: FR_URL },
];

const faq = [
  { q: 'كم تكلفة إنشاء موقع إلكتروني في تطوان؟', a: `تبدأ مواقعنا الاحترافية من ${PRICE}، شاملة النصوص المحسّنة لمحركات البحث، والاستضافة للسنة الأولى، والظهور في أدوات الذكاء الاصطناعي مثل ChatGPT. سعر ثابت متفق عليه مسبقاً — بدون مفاجآت.` },
  { q: 'هل تعملون عن بُعد أم في تطوان؟', a: 'الاثنان معاً. AZLA استوديو هولندي بجذور تطوانية: نعمل عبر واتساب ومكالمات الفيديو، ونتواجد في تطوان بانتظام للقاء عملائنا.' },
  { q: 'ما معنى الظهور في ChatGPT؟', a: 'أصبح الزبائن يسألون الذكاء الاصطناعي عن أفضل فندق أو مطعم أو مكتب في المدينة. نحن نجهّز موقعك تقنياً ليوصي به الذكاء الاصطناعي — خدمة لا تقدمها تقريباً أي وكالة في المغرب حالياً.' },
  { q: 'كم يستغرق إنجاز الموقع؟', a: 'عادةً 3 إلى 4 أسابيع من أول تواصل حتى الإطلاق: التصميم في الأسبوع الأول، التطوير والنصوص في الأسبوعين الثاني والثالث، والإطلاق في الأسبوع الرابع.' },
  { q: 'هل سيكون الموقع سريعاً ومناسباً للهاتف؟', a: 'نعم — هذه علامتنا المميزة. يفتح الموقع في أقل من ثانية واحدة حتى بشبكة 3G، ومصمم أولاً للهاتف حيث يتصفح أغلب زبائنك.' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'تصميم مواقع إلكترونية في تطوان',
    description: 'تصميم مواقع احترافية في تطوان بمعايير أوروبية: سرعة تحميل أقل من ثانية، ظهور في جوجل وفي أدوات الذكاء الاصطناعي مثل ChatGPT.',
    provider: { '@id': `${SITE.domain}/#organization` },
    areaServed: [{ '@type': 'City', name: 'Tétouan' }, { '@type': 'Country', name: 'Maroc' }],
    serviceType: 'تصميم مواقع',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((i) => ({ '@type': 'Question', name: i.q, acceptedAnswer: { '@type': 'Answer', text: i.a } })),
  },
];
---

<Base
  title="تصميم مواقع تطوان | وكالة ويب بمعايير أوروبية — AZLA"
  description="تصميم مواقع إلكترونية احترافية في تطوان: معايير أوروبية، تحميل أقل من ثانية، ظهور في جوجل وChatGPT. جذور تطوانية وجودة هولندية."
  lang="ar"
  dir="rtl"
  chrome={false}
  alternates={alternates}
  schema={schema}
>
  <header class="ar-header">
    <div class="container ar-header-inner">
      <a href="/ar/tasmim-mawaqi-tetouan" class="logo">AZLA<span class="accent">.</span></a>
      <nav class="ar-nav">
        <a href="/fr/creation-site-web-tetouan" class="lang-link">Français</a>
        <a href="/" class="lang-link">NL</a>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary ar-cta">عرض سعر مجاني</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="glow" style="top:-120px; left:-80px; width:460px; height:460px; background:var(--accent);"></div>
    <div class="container">
      <span class="kicker">وكالة ويب · تطوان وشمال المغرب</span>
      <h1>موقع إلكتروني <span class="accent">بمعايير أوروبية</span><br />وبجذور تطوانية</h1>
      <p class="lead">
        AZLA تصمم مواقع احترافية لشركات تطوان: تحميل في أقل من ثانية، ظهور في جوجل،
        وتوصيات من أدوات الذكاء الاصطناعي مثل ChatGPT. جودة هولندية، مصممة للمغرب.
      </p>
      <div class="hero-actions">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary">اطلب عرض سعر عبر واتساب</a>
        <a href="#tarifs" class="btn btn-ghost">الأسعار</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <span class="kicker">لماذا AZLA</span>
      <h2>ما لا تقدمه الوكالات المحلية (بعد)</h2>
      <div class="grid-3 mt-2">
        <div class="card reveal">
          <h3>سرعة أقل من ثانية</h3>
          <p class="muted" style="margin:0">أغلب المواقع في المغرب تفتح في 4 إلى 8 ثوانٍ فتخسر نصف زوارها. مواقعنا تفتح في أقل من ثانية حتى بشبكة ضعيفة — وجوجل يكافئ ذلك مباشرة.</p>
        </div>
        <div class="card reveal">
          <h3>الظهور في ChatGPT</h3>
          <p class="muted" style="margin:0">زبائنك يسألون الذكاء الاصطناعي عن أفضل رياض أو مطعم أو مكتب. نجهّز موقعك ليظهر في هذه التوصيات — أسبقية لا يملكها أحد تقريباً في المغرب.</p>
        </div>
        <div class="card reveal">
          <h3>تصميم أوروبي فاخر</h3>
          <p class="muted" style="margin:0">تصميم مخصص يبني الثقة لدى الزبون المغربي والسائح الأوروبي معاً — مثالي للسياحة والعقارات والخدمات الراقية.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="kicker">لمن هذه الخدمة</span>
      <h2>مصمّم لشركات تطوان</h2>
      <div class="grid-3 mt-2">
        <div class="card reveal"><h3>الرياضات والفنادق</h3><p class="muted" style="margin:0">حجوزات مباشرة بدل عمولات Booking. موقع متعدد اللغات يقنع الزوار الأوروبيين.</p></div>
        <div class="card reveal"><h3>المطاعم والمقاهي</h3><p class="muted" style="margin:0">قائمة طعام رقمية، حجز عبر واتساب، وصور تفتح الشهية — مع صفحة جوجل مثالية.</p></div>
        <div class="card reveal"><h3>المهن الحرة والخدمات</h3><p class="muted" style="margin:0">محامون، عيادات، عقارات، حرفيون: موقع يجعل مكتبك المرجع الأول في المنطقة.</p></div>
      </div>
    </div>
  </section>

  <section class="section section-alt" id="tarifs">
    <div class="container">
      <span class="kicker">الأسعار</span>
      <h2>استثمار، وليس مصروفاً</h2>
      <div class="grid-2 mt-2" style="max-width:860px">
        <div class="card reveal">
          <h3>الموقع الاحترافي</h3>
          <p class="muted">موقع مخصص من 5 إلى 8 صفحات، نصوص محسّنة، SEO وظهور في الذكاء الاصطناعي، مع استضافة السنة الأولى.</p>
          <p style="font-family:var(--font-display); font-size:1.9rem; font-weight:700; margin:0" class="accent">ابتداءً من {PRICE}</p>
        </div>
        <div class="card reveal">
          <h3>حسب الطلب</h3>
          <p class="muted">متجر إلكتروني، حجز أونلاين، أو مشروع خاص؟ كل مشروع يحصل على سعر ثابت متفق عليه مسبقاً.</p>
          <a href={wa} target="_blank" rel="noopener" class="btn btn-ghost">اطلب عرض سعر</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">
      <span class="kicker">أسئلة شائعة</span>
      <h2>أسئلة يطرحها عملاؤنا</h2>
      <div class="mt-2">
        {faq.map((item) => (
          <details class="faq-item reveal">
            <summary>{item.q}</summary>
            <p class="muted">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container center">
      <h2>لنتحدث عن مشروعك</h2>
      <p class="lead" style="margin:0 auto 2rem">نرد في أقل من 24 ساعة — بالعربية أو الدارجة أو الفرنسية. أول استشارة مجانية وبدون التزام.</p>
      <a href={wa} target="_blank" rel="noopener" class="btn btn-primary">راسلنا على واتساب</a>
    </div>
  </section>

  <footer class="ar-footer">
    <div class="container ar-footer-inner">
      <span class="logo">AZLA<span class="accent">.</span></span>
      <span class="muted">تطوان · روتردام — {SITE.email} · <a href={wa} style="color:var(--accent)">واتساب</a> · <a href="https://www.instagram.com/azlasolutions/" style="color:var(--text)">إنستغرام</a></span>
      <span class="muted">© 2026 AZLA Solutions · <a href="/fr/creation-site-web-tetouan" style="color:var(--text)">Français</a> · <a href="/" style="color:var(--text)">Nederlands</a></span>
    </div>
  </footer>
</Base>

<style>
  .ar-header { position: sticky; top: 0; z-index: 50; background: rgba(10,10,15,.85); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); }
  .ar-header-inner { display: flex; align-items: center; justify-content: space-between; height: 70px; }
  .logo { font-family: var(--font-display); font-weight: 700; font-size: 1.4rem; text-decoration: none; }
  .ar-nav { display: flex; align-items: center; gap: 1.2rem; }
  .lang-link { color: var(--muted); text-decoration: none; font-size: .95rem; }
  .lang-link:hover { color: var(--accent); }
  .ar-cta { padding: .55rem 1.2rem; font-size: .9rem; }
  .hero { position: relative; overflow: hidden; padding: clamp(4.5rem, 10vw, 8rem) 0 clamp(3.5rem, 7vw, 5rem); }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2.2rem; }
  .faq-item { border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); margin-bottom: .8rem; padding: 0 1.4rem; }
  summary { cursor: pointer; font-family: var(--font-display); font-weight: 600; padding: 1.2rem 0; list-style: none; position: relative; padding-inline-end: 2rem; }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: '+'; position: absolute; inset-inline-end: 0; top: 50%; transform: translateY(-50%); color: var(--accent); font-size: 1.4rem; }
  details[open] summary::after { content: '–'; }
  .faq-item p { padding-bottom: 1.2rem; margin: 0; }
  .ar-footer { border-top: 1px solid var(--border); background: var(--bg-elev); padding: 2rem 0; margin-top: 3rem; }
  .ar-footer-inner { display: flex; flex-direction: column; gap: .5rem; align-items: center; text-align: center; font-size: .9rem; }
  .ar-footer a { text-decoration: none; }
</style>
