---
import ArShell from '../../layouts/ArShell.astro';
import { SITE } from '../../consts';

const ACCESS_KEY = 'bac737c4-5025-4369-a94f-70e1f09b457d';
const wa = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('السلام عليكم! أريد عرض سعر لموقع إلكتروني.')}`;
const alternates = [
  { hreflang: 'fr', href: `${SITE.domain}/fr/contact` },
  { hreflang: 'ar', href: `${SITE.domain}/ar/contact` },
  { hreflang: 'nl', href: `${SITE.domain}/contact` },
  { hreflang: 'x-default', href: `${SITE.domain}/fr/contact` },
];
---

<ArShell
  title="اتصل بنا | عرض سعر مجاني خلال 24 ساعة — AZLA"
  description="تواصل مع AZLA: واتساب، بريد إلكتروني أو نموذج. نرد في أقل من 24 ساعة بالعربية أو الدارجة أو الفرنسية. عرض سعر مجاني وبدون التزام."
  alternates={alternates}
  frUrl="/fr/contact"
>
  <section class="hero">
    <div class="container contact-grid">
      <div>
        <span class="kicker">اتصل بنا</span>
        <h1>لنتحدث عن <span class="accent">مشروعك</span></h1>
        <p class="lead">نرد في أقل من 24 ساعة — بالعربية أو الدارجة أو الفرنسية. أول استشارة مجانية وبدون التزام.</p>
        <div class="contact-options">
          <a href={wa} target="_blank" rel="noopener" class="contact-line"><strong>واتساب</strong><span class="muted">الأسرع — غالباً نرد خلال ساعة</span></a>
          <a href={`mailto:${SITE.email}`} class="contact-line"><strong>{SITE.email}</strong><span class="muted">رد خلال 24 ساعة</span></a>
          <a href="https://www.instagram.com/azlasolutions/" target="_blank" rel="noopener" class="contact-line"><strong>azlasolutions@</strong><span class="muted">تابع أعمالنا على إنستغرام</span></a>
        </div>
      </div>
      <div class="card form-card">
        <h3>صف لنا مشروعك</h3>
        <form action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value={ACCESS_KEY} />
          <input type="hidden" name="subject" value="طلب جديد (AR) عبر azlasolutions.com" />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
          <label for="name">الاسم *</label>
          <input id="name" type="text" name="name" required placeholder="اسمك" />
          <label for="email">البريد الإلكتروني *</label>
          <input id="email" type="email" name="email" required placeholder="name@company.com" />
          <label for="phone">الهاتف / واتساب</label>
          <input id="phone" type="tel" name="phone" placeholder="+212 ..." />
          <label for="message">مشروعك *</label>
          <textarea id="message" name="message" rows="5" required placeholder="ما الذي تريد تحقيقه؟"></textarea>
          <button type="submit" class="btn btn-primary" style="border:none">إرسال</button>
        </form>
      </div>
    </div>
  </section>
</ArShell>

<style>
  .hero { padding: clamp(4.5rem, 9vw, 7rem) 0; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 4rem; align-items: start; }
  .contact-options { display: flex; flex-direction: column; gap: .9rem; margin-top: 2.2rem; }
  .contact-line { display: flex; flex-direction: column; text-decoration: none; border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1rem 1.3rem; }
  .contact-line:hover { border-color: var(--accent); }
  .contact-line strong { font-family: var(--font-display); }
  .contact-line span { font-size: .85rem; }
  .form-card { padding: 2.2rem; }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; } }
</style>
