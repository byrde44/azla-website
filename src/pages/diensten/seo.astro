import ServicePage from '../../components/ServicePage.astro';
---

<ServicePage
  metaTitle="SEO-bureau regio Rotterdam | Gevonden in Google én ChatGPT — AZLA"
  metaDescription="Structureel meer organische leads. AZLA combineert bewezen SEO met AI-vindbaarheid (GEO): bovenaan in Google en aanbevolen door ChatGPT, Perplexity en Gemini."
  serviceName="SEO & AI-vindbaarheid (GEO)"
  kicker="SEO & AI-vindbaarheid"
  heroTitle='Gevonden worden waar je klanten <span class="accent">nú zoeken</span>'
  heroLead="Google blijft belangrijk, maar je klanten vragen ook aan ChatGPT welk bureau of bedrijf ze moeten kiezen. Wij zorgen dat jij op beide plekken het antwoord bent — met SEO én GEO (Generative Engine Optimization)."
  blocks={[
    { title: 'Lokale SEO die snel scoort', text: 'Voor termen als "jouw dienst + jouw stad" is de concurrentie te verslaan. Onze klanten zien voor lokale zoektermen vaak binnen 4-8 weken beweging in rankings en aanvragen.' },
    { title: 'AI-vindbaarheid (GEO)', text: 'Onderzoek van Princeton en Georgia Tech toont dat GEO-geoptimaliseerde content 30-115% vaker verschijnt in AI-antwoorden. Wij passen die technieken toe: structured data, llms.txt, citeerbare content en autoriteitsopbouw.' },
    { title: 'Content die rankt én verkoopt', text: 'Blogartikelen en landingspagina’s gericht op zoektermen met koopintentie. Geen woordvulling, maar content die bezoekers overtuigt en zoekmachines voedt.' },
    { title: 'Technische SEO', text: 'Laadsnelheid, Core Web Vitals, schema markup, interne linkstructuur, crawlbaarheid. Het onzichtbare fundament dat het verschil maakt tussen pagina 1 en pagina 3.' },
    { title: 'Autoriteit opbouwen', text: 'Vermeldingen en links van relevante, betrouwbare sites — de bronnen die Google én AI-modellen vertrouwen als ze bepalen wie ze aanbevelen.' },
    { title: 'Glasheldere rapportage', text: 'Maandelijks zie je precies: rankings, bezoekers, aanvragen en wat we die maand deden en gaan doen. Geen wollige rapporten, wel resultaat.' },
  ]}
  steps={[
    { title: 'SEO & AI-audit', text: 'We analyseren je huidige vindbaarheid in Google én in AI-zoekmachines, plus die van je drie grootste concurrenten. Je ziet zwart-op-wit waar de kansen liggen.' },
    { title: 'Strategie & prioriteiten', text: 'Een concreet plan: welke zoektermen, welke content, welke technische fixes — geordend op impact, zodat de snelste winst eerst komt.' },
    { title: 'Uitvoering', text: 'Wij schrijven, optimaliseren en bouwen. Elke maand nieuwe content en verbeteringen, volledig uit handen genomen.' },
    { title: 'Meten & opschalen', text: 'Wat werkt krijgt meer aandacht, wat niet werkt gaat eruit. Zo groeit je organische verkeer maand op maand.' },
  ]}
  faq={[
    { q: 'Hoe lang duurt het voordat SEO resultaat oplevert?', a: 'Lokale zoektermen: vaak 4-8 weken. Landelijke competitieve termen: 3-12 maanden. SEO is een investering die zich opstapelt — de leads die je organisch binnenhaalt kosten daarna niets meer, in tegenstelling tot advertenties.' },
    { q: 'Wat is GEO (Generative Engine Optimization)?', a: 'GEO is het optimaliseren van je website zodat AI-assistenten zoals ChatGPT, Perplexity en Gemini jouw bedrijf citeren en aanbevelen in hun antwoorden. Het omvat structured data, citeerbare content, statistieken, autoriteitsopbouw en technische signalen zoals llms.txt.' },
    { q: 'Wat kost SEO per maand?', a: 'Onze SEO-trajecten starten vanaf €750 per maand, inclusief content, techniek en rapportage. De juiste investering hangt af van je markt en ambitie — dat bespreken we eerlijk in het strategiegesprek.' },
    { q: 'Kunnen jullie garanderen dat ik op nummer 1 kom?', a: 'Nee — en wantrouw ieder bureau dat dat wél belooft. Wat we wel kunnen: laten zien wat we voor vergelijkbare bedrijven bereikten, en volledig transparant rapporteren zodat je elke maand ziet dat we de goede kant op gaan.' },
  ]}
/>
