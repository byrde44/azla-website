---
// FAQ met automatische FAQPage schema.org markup (belangrijk voor Google én AI-zoekmachines)
interface Props {
  items: { q: string; a: string }[];
  title?: string;
}
const { items, title = 'Veelgestelde vragen' } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((i) => ({
    '@type': 'Question',
    name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a },
  })),
};
---

<section class="section">
  <div class="container faq-wrap">
    <span class="kicker">FAQ</span>
    <h2>{title}</h2>
    <div class="faq-list mt-2">
      {items.map((item) => (
        <details class="faq-item reveal">
          <summary>{item.q}</summary>
          <p class="muted">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq-wrap { max-width: 820px; }
  .faq-item {
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    background: var(--surface); margin-bottom: .8rem; padding: 0 1.4rem;
  }
  summary {
    cursor: pointer; font-family: var(--font-display); font-weight: 600;
    padding: 1.2rem 0; list-style: none; position: relative; padding-right: 2rem;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after {
    content: '+'; position: absolute; right: 0; top: 50%; transform: translateY(-50%);
    color: var(--accent); font-size: 1.4rem; transition: transform .2s;
  }
  details[open] summary::after { transform: translateY(-50%) rotate(45deg); }
  .faq-item p { padding-bottom: 1.2rem; margin: 0; }
</style>
